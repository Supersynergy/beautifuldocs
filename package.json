{
  "name": "beautifuldocs",
  "version": "0.1.0",
  "description": "Beautiful PDFs, slides & documents from Markdown. CLI-first, AI-powered, stunning design.",
  "type": "module",
  "bin": {
    "beautifuldocs": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile=beautifuldocs",
    "test": "bun test"
  },
  "keywords": [
    "pdf",
    "markdown",
    "slides",
    "presentation",
    "document-generator",
    "cli",
    "beautiful",
    "design",
    "templates"
  ],
  "author": "SuperSynergy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/supersynergyapp/beautifuldocs"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "marked-gfm-heading-id": "^3.2.0",
    "playwright": "^1.42.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  }
}
